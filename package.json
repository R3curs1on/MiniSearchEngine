{
  "name": "mini-search-engine-api",
  "version": "1.0.0",
  "description": "TF-IDF search engine API — MySQL backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test:js": "node --test tests/search_utils.test.js",
    "test:py": "python -m unittest tests/test_indexer_tokenizer.py",
    "test": "npm run test:js && npm run test:py",
    "pipeline": "bash scripts/run_pipeline.sh"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^4.22.1",
    "mysql2": "^3.15.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
